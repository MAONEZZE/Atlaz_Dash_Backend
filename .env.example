# Google Sheets API
GOOGLE_SHEETS_CREDENTIALS_JSON={"type": "service_account", "project_id": "...", "private_key_id": "...", "private_key": "...", "client_email": "...", "client_id": "...", "auth_uri": "...", "token_uri": "...", "auth_provider_x509_cert_url": "...", "client_x509_cert_url": "..."}
DEFAULT_SPREADSHEET_ID=your-spreadsheet-id

# Database (Supabase)
DATABASE_URL=postgresql://user:password@host:5432/database

# n8n Statistics API
N8N_STATISTICS_URL=https://n8n.learningbrands.cloud/webhook/statistic

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# Debug Routes
DEBUG_ROUTES_ENABLED=false

# Image Tokens (for user profile images)
VITE_IMG_JACOB_TOKEN=
VITE_IMG_JONATHAN_TOKEN=
VITE_IMG_ALEX_TOKEN=
VITE_IMG_JENNIFER_TOKEN=

# Logging
LOG_LEVEL=INFO
